node_modules/
dist/
.next/
.env
*.local
.DS_Store
*.tsbuildinfo
.claude

# Challenge scoring logic — encrypted versions (.enc) committed instead
packages/api/src/challenges/*/scorer.ts
packages/api/src/challenges/*/data.ts
# Keep template files for reference
!packages/api/src/challenges/_template/scorer.ts
!packages/api/src/challenges/_template/data.ts
# Keep community dir unaffected (uses DB storage)
!packages/api/src/challenges/community/**/scorer.ts
!packages/api/src/challenges/community/**/data.ts
# Alpha-genesis: commit plaintext until SCORING_KEY is synced with CI
!packages/api/src/challenges/alpha-genesis/scorer.ts
!packages/api/src/challenges/alpha-genesis/data.ts

# direnv
.envrc
