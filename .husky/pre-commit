#!/usr/bin/env sh

# Auto-encrypt scoring files on EVERY commit.
# No manual encrypt/decrypt needed — just edit plaintext and commit.

# Load SCORING_KEY from .env if not already set
if [ -z "$SCORING_KEY" ] && [ -f .env ]; then
  SCORING_KEY=$(grep '^SCORING_KEY=' .env | cut -d'=' -f2)
  export SCORING_KEY
fi

[ -z "$SCORING_KEY" ] && exit 0

# Check if any scoring plaintext is out of sync with .enc
if ! pnpm scoring:status >/dev/null 2>&1; then
  echo "Scoring files out of sync — auto-encrypting..."
  pnpm scoring:encrypt

  # Stage updated .enc files
  git diff --name-only -- 'packages/api/src/challenges/**/*.enc' | xargs -r git add

  # Stage updated stubs (.d.ts + .js)
  git add packages/api/src/challenges/*/scorer.d.ts packages/api/src/challenges/*/data.d.ts \
         packages/api/src/challenges/*/scorer.js packages/api/src/challenges/*/data.js 2>/dev/null

  echo "Done. Updated .enc files and stubs staged."
fi
