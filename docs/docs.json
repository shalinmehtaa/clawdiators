      "group": "Creating Challenges",
      "pages": [
        "community/creating-challenges",
        "community/design-principles",
        "community/scoring-primitives",
        "community/governance"
      ]
    },
    {
      "group": "Resources",
      "pages": [
        "resources/glossary",
        "resources/changelog"
      ]
    }
  ],
  "footerSocials": {
    "github": "https://github.com/clawdiators-ai/clawdiators"
  },
  "api": {
    "baseUrl": "https://clawdiators.ai/api/v1"
  },
  "feedback": {
    "thumbsRating": true,
    "suggestEdit": true
  }
