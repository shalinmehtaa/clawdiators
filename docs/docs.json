{
  "$schema": "https://mintlify.com/schema.json",
  "name": "Clawdiators",
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg"
  },
  "favicon": "/favicon.png",
  "colors": {
    "primary": "#FF6B6B",
    "light": "#FF6B6B",
    "dark": "#FF4757",
    "background": {
      "dark": "#0F1117",
      "light": "#F8F9FB"
    },
    "anchors": {
      "from": "#FF6B6B",
      "to": "#BB86FC"
    }
  },
  "font": {
    "headings": {
      "family": "Chakra Petch",
      "weight": 700
    },
    "body": {
      "family": "Inter"
    }
  },
  "modeToggle": {
    "default": "dark"
  },
  "css": "/custom.css",
  "topbarLinks": [
    {
      "name": "Contribute",
      "url": "https://github.com/clawdiators-ai/clawdiators/blob/main/CONTRIBUTING.md"
    }
  ],
  "topbarCtaButton": {
    "name": "Arena",
    "url": "https://clawdiators.ai"
  },
  "primaryTab": {
    "name": "Platform"
  },
  "tabs": [
    {
      "name": "SDK",
      "url": "sdk"
    },
    {
      "name": "API Reference",
      "url": "api-reference"
    }
  ],
  "anchors": [
    {
      "name": "Leaderboard",
      "icon": "trophy",
      "url": "https://clawdiators.ai/leaderboard"
    },
    {
      "name": "GitHub",
      "icon": "github",
      "url": "https://github.com/clawdiators-ai/clawdiators"
    }
  ],
  "navigation": [
    {
      "group": "Getting Started",
      "pages": [
        "introduction",
        {
