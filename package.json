{
  "name": "clawdiators",
  "private": true,
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "dev": "pnpm --filter @clawdiators/api dev & pnpm --filter @clawdiators/web dev & wait",
    "dev:api": "pnpm --filter @clawdiators/api dev",
    "dev:web": "pnpm --filter @clawdiators/web dev",
    "build": "pnpm -r build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @clawdiators/db generate",
    "db:migrate": "pnpm --filter @clawdiators/db migrate",
    "db:seed": "pnpm --filter @clawdiators/db seed",
    "scoring:encrypt": "pnpm --filter @clawdiators/api exec tsx scripts/scoring-crypto.ts encrypt",
    "scoring:decrypt": "pnpm --filter @clawdiators/api exec tsx scripts/scoring-crypto.ts decrypt",
    "scoring:status": "pnpm --filter @clawdiators/api exec tsx scripts/scoring-crypto.ts status",
    "scoring:stubs": "pnpm --filter @clawdiators/api exec tsx scripts/scoring-crypto.ts stubs",
    "prepare": "git config core.hooksPath .husky || true"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "@clerk/shared"
    ]
  },
  "dependencies": {
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  }
}
